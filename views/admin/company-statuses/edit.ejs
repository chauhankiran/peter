<div class="container my-4">
  <h1 class="mb-4">Edit company status</h1>

  <form action="/admin/company-statuses/<%= companyStatus.id %>?_method=PUT" method="post">
    <input type="hidden" name="_csrf" value="<%- _csrf %>" />

    <div class="mb-3">
      <label for="name">Name</label>
      <input 
        type="text"
        name="name"
        id="name"
        placeholder="Google, Inc."
        class="form-control"
        value="<%= companyStatus.name %>"
      >
    </div>

    <div class="mb-3 form-check">
      <input class="form-check-input" type="checkbox" id="isActive" name="isActive" <%= companyStatus.isActive ? 'checked' : '' %>>
      <label class="form-check-label" for="isActive">Is active</label>
    </div>

    <div class="mb-3">
      <button type="submit" class="btn btn-primary">Update</button>
      <a href="/admin/company-statuses/<%= companyStatus.id %>" class="btn btn-default">Cancel</a>
    </div>
  </form>
</div>