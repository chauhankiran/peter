<div class="container my-4">
  <div class="row align-items-center">
    <div class="col-md-8">
      <h1>Companies</h1>
    </div>
    <div class="col-md-4 text-end">
      <a href="/companies/new" class="btn btn-primary">Add company</a>
    </div>
  </div>

  <div class="row">
    <div class="col-md-12">
      <form action="/companies">
        <input type="text" name="search" id="search" class="form-control mb-2" placeholder="Search company by name and press 'Enter'" value="<%= req.search %>">
        <input type="submit">
      </form>
    </div>
  </div>

  <div class="row">
    <div class="col-md-12">
      <table class="table table-hover table-bordered table-stripped">
        <thead>
          <tr>
            <th>Id</th>
            <th>Name</th>
            <th>Website</th>
            <th>Created by</th>
            <th>Updated by</th>
            <th>Actions</th>
          </tr>
        </thead>
        <tbody>
          <% for (let company of companies) { %>
            <tr>
              <td>
                <a href="/companies/<%= company.id %>">
                  <%= company.id %>
                </a>
              </td>
              <td>
                <a href="/companies/<%= company.id %>">
                  <%= company.name %>
                </a>
              </td>
              <td><%= company.website %></td>
              <td><%= company.createdBy?.fullName || "-" %></td>
              <td><%= company.updatedBy?.fullName || "-" %></td>
              <td>
                <a href="/companies/<%= company.id %>/edit">Edit</a>
              </td>
            </tr>
          <% } %>
        </tbody>
      </table>
    </div>

    <div class="col-md-12">
      <nav>
        <ul class="pagination">
          <li class="page-item <%= pagination.currentPage === pagination.firstPage ? 'disabled' : '' %>">
            <a class="page-link" href="/<%= pagination.firstPageUrl %>">First</a>
          </li>

          <li class="page-item <%= pagination.currentPage === pagination.prevPage ? 'disabled' : '' %>">
            <a class="page-link" href="<%= pagination.prevPageUrl %>">Previous</a>
          </li>
          
          <li class="page-item <%= pagination.currentPage === pagination.lastPage ? 'disabled' : '' %>">
            <a class="page-link" href="<%= pagination.nextPageUrl %>">Next</a>
          </li>
          
          <li class="page-item <%= pagination.currentPage === pagination.lastPage ? 'disabled' : ''%>">
            <a class="page-link" href="<%= pagination.lastPageUrl %>">Last</a>
          </li>
        </ul>
      </nav>
    </div>
  </div>
</div>